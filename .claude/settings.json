{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/sync-pull.sh",
            "statusMessage": "GitHub から最新を取得中..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pre-tool-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/sync-push.sh",
            "statusMessage": "GitHub へプッシュ中..."
          }
        ]
      }
    ]
  }
}
