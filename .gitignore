# SQLite database (院内LAN環境で生成される実データ)
data/*.db

# 患者情報編集ストア（個人情報保護のため Git 追跡禁止）
data/patient_names.json

# 患者ステータス（カンファ区分）ストア（ユーザー固有の運用データのため Git 追跡禁止）
data/patient_status.json

# 患者ステータス履歴（週次カンファの変化履歴、個人運用データのため Git 追跡禁止）
data/patient_status_history.json

# 退院予定ストア（ユーザー固有の運用データのため Git 追跡禁止）
data/discharge_plans.json

# 実データ由来の教育用デモ CSV（生成物、運用メタに近いため Git 追跡禁止）
data/demo_from_actual_*/

# 注: data/actual_admissions_*.csv は以下の理由で Git 追跡対象とする（.gitignore に入れない）
#   - patient_id は UUID v5 ハッシュ（不可逆）
#   - attending_doctor は全て「不明」
#   - age_years は年単位のみ（既存追跡中の admissions_consolidated_dedup.csv の day 精度より匿名性が高い）
#   - notes 列は全て空
#   - Streamlit Cloud 側で「📉 過去実績分析」タブと施設基準レポートが動作するために必要

# 予測 snapshot（backtesting 用、実運用で蓄積される日次データ）
data/forecast_snapshots/

# Playwright
playwright/screenshots/*.png
playwright-report/
test-results/

# 週末・祝日 KPI スライド作業ディレクトリの npm 関連
